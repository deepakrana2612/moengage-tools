{
  "name": "moengage-tools",
  "version": "1.0.0",
  "description": "T-Mobile MoEngage Utility Suite",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "[ -f client/package.json ] && (cd client && npm install && npm run build) || echo 'No React app found in client/ — skipping build'",
    "dev": "nodemon server.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "http-proxy-middleware": "^2.0.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
