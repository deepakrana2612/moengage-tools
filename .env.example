# ─── MoEngage Tools — Environment Variables ───────────────────────────────────
# Copy this file to .env for local development
# On Render: add these via Dashboard → Environment tab (never commit .env)

# Server port (Render sets PORT automatically; 3000 is the local default)
PORT=3000

# MoEngage Data Center base URL
# DC 101 (US): https://api-01.moengage.com
# DC 02:       https://api-02.moengage.com
# DC 03:       https://api-03.moengage.com
MOENGAGE_BASE_URL=https://api-01.moengage.com

# MoEngage App credentials (found in MoEngage Dashboard → Settings → APIs)
MOENGAGE_APP_ID=your_app_id_here
MOENGAGE_API_KEY=your_api_key_here
