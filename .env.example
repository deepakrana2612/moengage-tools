# ─── MoEngage Tools — Environment Variables ───────────────────────────────────

PORT=3000

# ─── User Authentication ──────────────────────────────────────────────────────
# JSON array of users. Managed automatically via the /admin UI.
# To bootstrap the first admin, set this manually then use the UI for all future changes.
# Example:
# APP_USERS=[{"username":"deepak","password":"<hash>","email":"deepak@t-mobile.com","isAdmin":true,"displayName":"Deepak","mustReset":false}]
APP_USERS=[{"username":"deepak.rana9@t-mobile.com","password":"30a4724be717bde82836dbd00e59c45f1c89f5d2407754d2e7a1a3905657d7d9","email":"deepak.rana@vml.com","displayName":"Deepak Rana","isAdmin":true,"mustReset":false}]

# ─── Render API (for saving users from the UI) ────────────────────────────────
# Get from: render.com → Avatar → Account Settings → API Keys
RENDER_API_KEY=rnd_syZy4WTXuto4gnKZ6KY8mKz4GC2Z
# Get from: your service URL on Render (srv-xxxxxxxx)
RENDER_SERVICE_ID=srv-d7hb971kh4rs73aaou5g

# ─── Gmail SMTP (for sending welcome + reset emails) ─────────────────────────
# Use a Gmail App Password — NOT your regular Gmail password.
# Enable at: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=deepak.rana26121@gmail.com
GMAIL_APP_PASSWORD=rfrl ttfp wxpm aaqq

# ─── App URL (used in email links) ───────────────────────────────────────────
