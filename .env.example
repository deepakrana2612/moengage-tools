# ─── MoEngage Tools — Environment Variables ───────────────────────────────────
# Copy this file to .env for local development.
# No MoEngage credentials stored here — passed per-request from the UI instead.

# Server port (Render sets this automatically; 3000 is the local default)
PORT=3000

# Flow dashboard base URL (only needed if your DC is not 101)
# FLOW_BASE_URL=https://dashboard-101.moengage.com
